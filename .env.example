# Server
PORT=3001
NODE_ENV=development

# Self-hosted mode — set to true to unlock all features with no limits
SELF_HOSTED=false

# Database
DB_PATH=./eudora.db

# Auth — generate with: openssl rand -base64 32
JWT_SECRET=replace-with-32-or-more-random-characters
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=7

# Encryption — generate with: openssl rand -hex 32
ENCRYPTION_KEY=replace-with-64-char-hex-string

# OpenAI OAuth (optional — register at platform.openai.com/oauth)
OPENAI_OAUTH_CLIENT_ID=
OPENAI_OAUTH_CLIENT_SECRET=
OPENAI_OAUTH_REDIRECT_URI=http://localhost:3001/auth/oauth/callback/openai

# Stripe (optional — required for cloud billing only)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PROFESSIONAL=
STRIPE_PRICE_ENTERPRISE=

# Frontend URL
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:3001
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Transactional email (Resend)
RESEND_API_KEY=re_your_key_here
RESEND_FROM=security@geteudora.com

# Private operator portal — backend only
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=change-this-to-a-long-random-secret
