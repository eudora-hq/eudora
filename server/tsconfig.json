{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "rootDir": "./src",
    "allowImportingTsExtensions": true,
    "noEmit": true
  },
  "include": [
    "src/audit/auditLogger.ts",
    "src/reports/complianceReport.ts",
    "src/routes/proxy.ts"
  ],
  "exclude": ["node_modules", "dist", "src/tests", "src/**/__tests__"]
}
